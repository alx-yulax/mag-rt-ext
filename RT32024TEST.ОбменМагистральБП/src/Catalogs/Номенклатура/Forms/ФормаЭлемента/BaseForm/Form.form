                  <textEdit>true</textEdit>
                  <textSize>Normal</textSize>
                  <dropListWidth>40</dropListWidth>
                </extInfo>
              </items>
              <items xsi:type="form:FormField">
                <name>ТипНоменклатуры</name>
                <id>1586</id>
                <title>
                  <key>ru</key>
                  <value>Тип</value>
                </title>
                <visible>true</visible>
                <enabled>true</enabled>
                <userVisible>
                  <common>true</common>
                </userVisible>
                <dataPath xsi:type="form:DataPath">
                  <segments>Объект.ТипНоменклатуры</segments>
                </dataPath>
                <skipOnInput>true</skipOnInput>
                <toolTip>
                  <key>ru</key>
                  <value>Для редактирования нажмите кнопку &quot;Разрешить редактирование&quot; из меню &quot;Еще&quot;</value>
                </toolTip>
                <toolTipRepresentation>Button</toolTipRepresentation>
                <extendedTooltip>
                  <name>ТипНоменклатурыРасширеннаяПодсказка</name>
                  <id>1588</id>
                  <title>
                    <key>ru</key>
                    <value>Определяет объем вводимой информации и возможные действия с номенклатурой.

Например:
&lt;fontsize 6>●&lt;/>  Тип Запас используется для товаров, материалов, продукции.
&lt;fontsize 6>●&lt;/>  Тип Услуга используется для услуг, оказанных организации и др..

Для редактирования нажмите кнопку &quot;Разрешить редактирование&quot; из меню &quot;Еще&quot;.

&lt;link e1cib/list/Справочник.КатегорииНоменклатуры>По умолчанию заполняется из категории.&lt;/></value>
                  </title>
                  <formatted>true</formatted>
                  <type>Label</type>
                  <autoMaxWidth>true</autoMaxWidth>
                  <autoMaxHeight>true</autoMaxHeight>
                  <extInfo xsi:type="form:LabelDecorationExtInfo">
                    <horizontalAlign>Left</horizontalAlign>
                  </extInfo>
                </extendedTooltip>
                <contextMenu>
                  <name>ТипНоменклатурыКонтекстноеМеню</name>
                  <id>1587</id>
                  <autoFill>true</autoFill>
                </contextMenu>
