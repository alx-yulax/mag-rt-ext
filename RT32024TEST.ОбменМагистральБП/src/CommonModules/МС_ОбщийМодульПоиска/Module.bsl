// @strict-types

#Область ПрограммныйИнтерфейс

// Найти номенклатуру полнотекстово.
// 
// Параметры:
//  СтрокаПоиска - Строка - поиска
//  РазмерПорции - Число - Размер порции
// 
// Возвращаемое значение:
//  Массив из СправочникСсылка.МС_НоменклатураБП
Функция НайтиНоменклатуруПолнотекстово(СтрокаПоиска, РазмерПорции = 20) Экспорт
	
	Результат = Новый Массив; //Массив из СправочникСсылка.МС_НоменклатураБП
	
	СтрокаПоиска = СокрЛП(СтрокаПоиска);
	
	Если ПустаяСтрока(СтрокаПоиска) Тогда
		Возврат Результат;
	КонецЕсли;
	
	РазмерПорции = ПолучитьБезопасныйРазмерПорции(РазмерПорции);
	
	// 1. Сначала ищем точное наименование.
	ТочныеСовпадения = НайтиНоменклатуруПоТочномуНаименованию(
		СтрокаПоиска,
		РазмерПорции
	);
	
	Если ТочныеСовпадения.Количество() > 0 Тогда
		Возврат ТочныеСовпадения;
	КонецЕсли;
	
	// 2. Потом уже полнотекстовый поиск.
	ПараметрыПоиска = РазобратьСтрокуПоискаНоменклатуры(СтрокаПоиска);
	
	Если Не ПоискДопустим(ПараметрыПоиска) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ВыражениеПоиска = СобратьЖесткоеВыражениеПоиска(ПараметрыПоиска);
	
	Если ПустаяСтрока(ВыражениеПоиска) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Кандидаты = ПолучитьКандидатовПолнотекстовогоПоиска(
		ВыражениеПоиска,
		РазмерПорции * 10
	);
	
	Если Кандидаты.Количество() > 0 Тогда
		
		Результат = ОтфильтроватьКандидатовПоНаименованию(
	Кандидаты,
	ПараметрыПоиска,
	РазмерПорции,
	СтрокаПоиска
);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции 

Функция НайтиНоменклатуруПоТочномуНаименованию(
	Знач СтрокаПоиска,
	РазмерПорции)
	
	Результат = Новый Массив;
	
	СтрокаПоиска = СокрЛП(СтрокаПоиска);
	
	Если ПустаяСтрока(СтрокаПоиска) Тогда
		Возврат Результат;
	КонецЕсли;
	
	НормализованнаяСтрокаПоиска = НормализоватьСтрокуДляТочногоСравнения(
		СтрокаПоиска
	);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ " + Формат(РазмерПорции * 5, "ЧГ=0") + "
	|	Номенклатура.Ссылка КАК Ссылка,
	|	Номенклатура.Наименование КАК Наименование
	|ИЗ
	|	Справочник.МС_НоменклатураБП КАК Номенклатура
	|ГДЕ
	|	НЕ Номенклатура.ПометкаУдаления
	|	И НЕ Номенклатура.ЭтоГруппа
	|	И ВРег(Номенклатура.Наименование) = &НаименованиеВРег";
	
	Запрос.УстановитьПараметр("НаименованиеВРег", ВРег(СтрокаПоиска));
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если НормализоватьСтрокуДляТочногоСравнения(Выборка.Наименование)
			= НормализованнаяСтрокаПоиска Тогда
			
			Результат.Добавить(Выборка.Ссылка);
			
			Если Результат.Количество() >= РазмерПорции Тогда
				Прервать;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции   

Функция НормализоватьСтрокуДляТочногоСравнения(Знач Строка)
	
	Строка = ВРег(СокрЛП(Строка));
	
	Строка = СтрЗаменить(Строка, Символы.ПС, " ");
	Строка = СтрЗаменить(Строка, Символы.ВК, " ");
	Строка = СтрЗаменить(Строка, Символы.Таб, " ");
	
	Пока Найти(Строка, "  ") > 0 Цикл
		Строка = СтрЗаменить(Строка, "  ", " ");
	КонецЦикла;
	
	Возврат СокрЛП(Строка);
	
КонецФункции

#КонецОбласти


#Область ПолнотекстовыйПоиск

Функция ПолучитьКандидатовПолнотекстовогоПоиска(ВыражениеПоиска, РазмерПорции)
	
	Кандидаты = Новый Массив;
	УжеДобавленные = Новый Соответствие;
	
	Попытка
		
		СписокПоиска = ПолнотекстовыйПоиск.СоздатьСписок(
			ВыражениеПоиска,
			РазмерПорции
		);
		
		СписокПоиска.ПолучатьОписание = Истина;
		СписокПоиска.ПорогНечеткости = 0;
		
		ОбластьПоиска = Новый Массив;
		ОбластьПоиска.Добавить(Метаданные.Справочники.МС_НоменклатураБП);
		
		СписокПоиска.ОбластьПоиска = ОбластьПоиска;
		СписокПоиска.ПерваяЧасть();
		
		Для Каждого ЭлементПоиска Из СписокПоиска Цикл
			
			Если ТипЗнч(ЭлементПоиска.Значение)
				<> Тип("СправочникСсылка.МС_НоменклатураБП") Тогда
				
				Продолжить;
				
			КонецЕсли;
			
			Если УжеДобавленные.Получить(ЭлементПоиска.Значение) = Неопределено Тогда
				
				Кандидаты.Добавить(ЭлементПоиска.Значение);
				УжеДобавленные.Вставить(ЭлементПоиска.Значение, Истина);
				
			КонецЕсли;
			
		КонецЦикла;
		
	Исключение
		
		Сообщить("Ошибка полнотекстового поиска: " + ОписаниеОшибки());
		
	КонецПопытки;
	
	Возврат Кандидаты;
	
КонецФункции



Функция СобратьЖесткоеВыражениеПоиска(ПараметрыПоиска)
	
	Части = Новый Массив;
	
	// В ППД отправляем только нормальные текстовые слова.
	// Составные размеры проверим потом вручную.
	Для Каждого Слово Из ПараметрыПоиска.ТекстовыеСлова Цикл
		Части.Добавить(Слово);
	КонецЦикла;
	
	Для Каждого Токен Из ПараметрыПоиска.КороткиеТокены Цикл
		Части.Добавить(Токен);
	КонецЦикла;
	
	Для Каждого Метрика Из ПараметрыПоиска.Метрики Цикл
		Части.Добавить(Метрика);
	КонецЦикла;
	
	// Обычные числа добавляем только если нет строгих составных размеров.
	// Иначе "25мм" опять может притянуть "25-7".
	Если ПараметрыПоиска.СоставныеРазмеры.Количество() = 0
		И ПараметрыПоиска.РазмерыСЕдиницами.Количество() = 0 Тогда
		
		Для Каждого Число Из ПараметрыПоиска.Числа Цикл
			Части.Добавить(Число);
		КонецЦикла;
		
	КонецЕсли;
	
	Результат = "";
	
	Для Каждого Часть Из Части Цикл
		
		Если Результат <> "" Тогда
			Результат = Результат + " И ";
		КонецЕсли;
		
		Результат = Результат + Часть;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти


#Область РазборСтрокиПоиска

Функция РазобратьСтрокуПоискаНоменклатуры(Знач СтрокаПоиска)
	
	Результат = Новый Структура;
	Результат.Вставить("ТекстовыеСлова", Новый Массив);
	Результат.Вставить("КороткиеТокены", Новый Массив);
	Результат.Вставить("Метрики", Новый Массив);
	Результат.Вставить("Числа", Новый Массив);
	Результат.Вставить("СоставныеРазмеры", Новый Массив);
	Результат.Вставить("РазмерыСЕдиницами", Новый Массив);
	Результат.Вставить("РазмерныеВыражения", Новый Массив);
	
	СтрокаПоиска = ВРег(СокрЛП(СтрокаПоиска));
	
	// Сначала сохраняем строгие размеры вида 5,5*19, 4*30, 10х100.
	ДобавитьРазмерныеВыраженияИзСтроки(СтрокаПоиска, Результат);
	
	СтрокаПоиска = ПодготовитьСтрокуКРазбору(СтрокаПоиска);
	
	Слова = СтрРазделить(СтрокаПоиска, " ", Ложь);
	
	Для Каждого Слово Из Слова Цикл
		
		Слово = СокрЛП(Слово);
		
		Если ПустаяСтрока(Слово) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЭтоЕдиницаИзмерения(Слово) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ЭтоПоисковыйОператор(Слово) Тогда
			Продолжить;
		КонецЕсли;
		
		Слово = НормализоватьСимволыВТокене(Слово);
		
		// 25ММ, 310ММ, 2ММ — строгий размер с единицей.
		Если ЭтоРазмерСЕдиницей(Слово) Тогда
			
			РазмерСЕдиницей = НормализоватьРазмерСЕдиницей(Слово);
			
			Если Результат.РазмерыСЕдиницами.Найти(РазмерСЕдиницей) = Неопределено Тогда
				Результат.РазмерыСЕдиницами.Добавить(РазмерСЕдиницей);
			КонецЕсли;
			
			Продолжить;
			
		КонецЕсли;
		
		// М6, М8, М10, М12.
		Если ЭтоМетрическийРазмер(Слово) Тогда
			
			Метрика = НормализоватьМетрическийРазмер(Слово);
			
			Если Результат.Метрики.Найти(Метрика) = Неопределено Тогда
				Результат.Метрики.Добавить(Метрика);
			КонецЕсли;
			
			Продолжить;
			
		КонецЕсли;
		
		// 2,5-5, 1,5-5, 25-7 — не разбиваем.
		Если ЭтоСоставнойРазмер(Слово) Тогда
			
			СоставнойРазмер = НормализоватьСоставнойРазмер(Слово);
			
			Если Результат.СоставныеРазмеры.Найти(СоставнойРазмер) = Неопределено Тогда
				Результат.СоставныеРазмеры.Добавить(СоставнойРазмер);
			КонецЕсли;
			
			Продолжить;
			
		КонецЕсли;
		
		Если ЭтоСтрокаИзЦифр(Слово) Тогда
			
			Если Результат.Числа.Найти(Слово) = Неопределено Тогда
				Результат.Числа.Добавить(Слово);
			КонецЕсли;
			
			Продолжить;
			
		КонецЕсли;
		
		Если ЭтоВажныйКороткийТокен(Слово) Тогда
			
			Если Результат.КороткиеТокены.Найти(Слово) = Неопределено Тогда
				Результат.КороткиеТокены.Добавить(Слово);
			КонецЕсли;
			
			Продолжить;
			
		КонецЕсли;
		
		Если СтрДлина(Слово) < 3 Тогда
			Продолжить;
		КонецЕсли;
		
		Если Результат.ТекстовыеСлова.Найти(Слово) = Неопределено Тогда
			Результат.ТекстовыеСлова.Добавить(Слово);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Процедура ДобавитьРазмерныеВыраженияИзСтроки(Знач Строка, ПараметрыПоиска)
	
	Строка = ПодготовитьСтрокуДляВыделенияРазмеров(Строка);
	
	Токены = СтрРазделить(Строка, " ", Ложь);
	
	Для Каждого Токен Из Токены Цикл
		
		Токен = СокрЛП(Токен);
		
		Если ПустаяСтрока(Токен) Тогда
			Продолжить;
		КонецЕсли;
		
		Токен = НормализоватьРазмерноеВыражение(Токен);
		
		Если ЭтоРазмерноеВыражение(Токен) Тогда
			
			Если ПараметрыПоиска.РазмерныеВыражения.Найти(Токен) = Неопределено Тогда
				ПараметрыПоиска.РазмерныеВыражения.Добавить(Токен);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры


Функция ПодготовитьСтрокуДляВыделенияРазмеров(Знач Строка)
	
	// Здесь НЕ трогаем запятую, дефис, звездочку, X/Х.
	// Они нужны для размеров: 5,5*19, 2,5-5, 10х100.
	Разделители = ".;:!?()[]{}<>/\|+=""" "'";
	
	Для НомерСимвола = 1 По СтрДлина(Разделители) Цикл
		
		Символ = Сред(Разделители, НомерСимвола, 1);
		Строка = СтрЗаменить(Строка, Символ, " ");
		
	КонецЦикла;
	
	Строка = СтрЗаменить(Строка, Символы.ПС, " ");
	Строка = СтрЗаменить(Строка, Символы.ВК, " ");
	Строка = СтрЗаменить(Строка, Символы.Таб, " ");
	
	Пока Найти(Строка, "  ") > 0 Цикл
		Строка = СтрЗаменить(Строка, "  ", " ");
	КонецЦикла;
	
	Возврат СокрЛП(Строка);
	
КонецФункции


Функция НормализоватьРазмерноеВыражение(Знач Токен)
	
	Токен = ВРег(СокрЛП(Токен));
	
	// Приводим разные варианты знака умножения к "*".
	Токен = СтрЗаменить(Токен, "×", "*");
	Токен = СтрЗаменить(Токен, "X", "*");
	Токен = СтрЗаменить(Токен, "Х", "*");
	
	// На случай записи 5.5*19.
	Токен = СтрЗаменить(Токен, ".", ",");
	
	// 5,5*19ММ считаем тем же размером, что 5,5*19.
	Токен = УдалитьЕдиницуПослеРазмерногоВыражения(Токен);
	
	Возврат Токен;
	
КонецФункции


Функция УдалитьЕдиницуПослеРазмерногоВыражения(Знач Токен)
	
	Единицы = ПолучитьСписокЕдиницИзмерения();
	
	Для Каждого Единица Из Единицы Цикл
		
		Если СтрДлина(Токен) <= СтрДлина(Единица) Тогда
			Продолжить;
		КонецЕсли;
		
		Если Прав(Токен, СтрДлина(Единица)) = Единица Тогда
			
			ТокенБезЕдиницы = Лев(
				Токен,
				СтрДлина(Токен) - СтрДлина(Единица)
			);
			
			Если ЭтоРазмерноеВыражениеБезУдаленияЕдиниц(ТокенБезЕдиницы) Тогда
				Возврат ТокенБезЕдиницы;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Токен;
	
КонецФункции


Функция ЭтоРазмерноеВыражение(Знач Токен)
	
	Токен = НормализоватьРазмерноеВыражение(Токен);
	
	Возврат ЭтоРазмерноеВыражениеБезУдаленияЕдиниц(Токен);
	
КонецФункции


Функция ЭтоРазмерноеВыражениеБезУдаленияЕдиниц(Знач Токен)
	
	Токен = СокрЛП(Токен);
	
	Если Найти(Токен, "*") = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Части = СтрРазделить(Токен, "*", Ложь);
	
	Если Части.Количество() < 2 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Для Каждого Часть Из Части Цикл
		
		Часть = СокрЛП(Часть);
		
		Если Не ЭтоЧислоИлиДесятичноеЧисло(Часть) Тогда
			Возврат Ложь;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции


Функция ЭтоЧислоИлиДесятичноеЧисло(Знач Строка)
	
	Строка = СокрЛП(Строка);
	
	Если ПустаяСтрока(Строка) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	КоличествоЗапятых = 0;
	
	Для НомерСимвола = 1 По СтрДлина(Строка) Цикл
		
		Символ = Сред(Строка, НомерСимвола, 1);
		
		Если Символ = "," Тогда
			
			КоличествоЗапятых = КоличествоЗапятых + 1;
			
			Если КоличествоЗапятых > 1 Тогда
				Возврат Ложь;
			КонецЕсли;
			
			Продолжить;
			
		КонецЕсли;
		
		Если Найти("0123456789", Символ) = 0 Тогда
			Возврат Ложь;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

Функция ЭтоМетрическийРазмер(Знач Слово)
	
	Слово = ВРег(СокрЛП(Слово));
	
	Если СтрДлина(Слово) < 2 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ПервыйСимвол = Лев(Слово, 1);
	
	// Поддерживаем и русскую М, и латинскую M.
	Если ПервыйСимвол <> "М" И ПервыйСимвол <> "M" Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Остаток = Сред(Слово, 2);
	
	Возврат ЭтоСтрокаИзЦифр(Остаток);
	
КонецФункции         

Функция НормализоватьМетрическийРазмер(Знач Слово)
	
	Слово = ВРег(СокрЛП(Слово));
	
	// Приводим латинскую M к русской М.
	Если Лев(Слово, 1) = "M" Тогда
		Слово = "М" + Сред(Слово, 2);
	КонецЕсли;
	
	Возврат Слово;
	
КонецФункции 

Функция ЭтоВажныйКороткийТокен(Знач Слово)
	
	Слово = ВРег(СокрЛП(Слово));
	
	Возврат Слово = "ОЦ"
	Или Слово = "ЧН"
	Или Слово = "БП"
	Или Слово = "БШ"
	Или Слово = "DIN";
	
КонецФункции

Функция ПодготовитьСтрокуКРазбору(Знач Строка)
	
	// Звездочку считаем разделителем обычных токенов:
	// 5,5*19 -> 5,5 19.
	// Но полный размер 5,5*19 мы уже заранее сохранили
	// в РазмерныеВыражения.
	Строка = СтрЗаменить(Строка, "*", " ");
	Строка = СтрЗаменить(Строка, "×", " ");
	
	// Х и X здесь НЕ заменяем.
	// Иначе можно сломать обычные слова.
	
	// Запятую и дефис НЕ трогаем:
	// 2,5-5 должно остаться 2,5-5.
	Разделители = ".;:!?()[]{}<>/\|+=""" "'";
	
	Для НомерСимвола = 1 По СтрДлина(Разделители) Цикл
		
		Символ = Сред(Разделители, НомерСимвола, 1);
		Строка = СтрЗаменить(Строка, Символ, " ");
		
	КонецЦикла;
	
	Строка = СтрЗаменить(Строка, Символы.ПС, " ");
	Строка = СтрЗаменить(Строка, Символы.ВК, " ");
	Строка = СтрЗаменить(Строка, Символы.Таб, " ");
	
	Пока Найти(Строка, "  ") > 0 Цикл
		Строка = СтрЗаменить(Строка, "  ", " ");
	КонецЦикла;
	
	Возврат СокрЛП(Строка);
	
КонецФункции

Функция НормализоватьСимволыВТокене(Знач Токен)
	
	Токен = ВРег(СокрЛП(Токен));
	
	// Латинская M -> русская М.
	Если Лев(Токен, 1) = "M" Тогда
		Токен = "М" + Сред(Токен, 2);
	КонецЕсли;
	
	Возврат Токен;
	
КонецФункции


Функция ЭтоРазмерСЕдиницей(Знач Токен)
	
	Токен = НормализоватьСимволыВТокене(Токен);
	
	Единицы = ПолучитьСписокЕдиницИзмерения();
	
	Для Каждого Единица Из Единицы Цикл
		
		Если СтрДлина(Токен) <= СтрДлина(Единица) Тогда
			Продолжить;
		КонецЕсли;
		
		Если Прав(Токен, СтрДлина(Единица)) = Единица Тогда
			
			ЧисловаяЧасть = Лев(
				Токен,
				СтрДлина(Токен) - СтрДлина(Единица)
			);
			
			Если ЭтоСтрокаИзЦифр(ЧисловаяЧасть) Тогда
				Возврат Истина;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции


Функция НормализоватьРазмерСЕдиницей(Знач Токен)
	
	Возврат НормализоватьСимволыВТокене(Токен);
	
КонецФункции


Функция ЭтоСоставнойРазмер(Знач Токен)
	
	Токен = СокрЛП(Токен);
	
	Если СтрДлина(Токен) < 3 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	ЕстьЦифра = Ложь;
	ЕстьРазделитель = Ложь;
	
	Для НомерСимвола = 1 По СтрДлина(Токен) Цикл
		
		Символ = Сред(Токен, НомерСимвола, 1);
		
		Если Найти("0123456789", Символ) > 0 Тогда
			ЕстьЦифра = Истина;
		КонецЕсли;
		
		Если Символ = "-" Или Символ = "," Тогда
			ЕстьРазделитель = Истина;
		КонецЕсли;
		
		Если Найти("0123456789-,", Символ) = 0 Тогда
			Возврат Ложь;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ЕстьЦифра И ЕстьРазделитель;
	
КонецФункции


Функция НормализоватьСоставнойРазмер(Знач Токен)
	
	Токен = ВРег(СокрЛП(Токен));
	
	// Запятую оставляем запятой.
	// Для твоих данных "2,5-5" должно сравниваться именно с "2,5-5".
	Возврат Токен;
	
КонецФункции

Функция УдалитьЕдиницуИзмеренияИзКонца(Знач Слово)
	
	Единицы = ПолучитьСписокЕдиницИзмерения();
	
	Для Каждого Единица Из Единицы Цикл
		
		Если СтрДлина(Слово) <= СтрДлина(Единица) Тогда
			Продолжить;
		КонецЕсли;
		
		Если Прав(Слово, СтрДлина(Единица)) = Единица Тогда
			
			СловоБезЕдиницы = Лев(
				Слово,
				СтрДлина(Слово) - СтрДлина(Единица)
			);
			
			Если ЭтоСтрокаИзЦифр(СловоБезЕдиницы) Тогда
				Возврат СловоБезЕдиницы;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Слово;
	
КонецФункции


Функция ПолучитьСписокЕдиницИзмерения()
	
	Единицы = Новый Массив;
	
	Единицы.Добавить("ММ");
	Единицы.Добавить("СМ");
	Единицы.Добавить("М");
	Единицы.Добавить("КГ");
	Единицы.Добавить("Г");
	Единицы.Добавить("Л");
	Единицы.Добавить("МЛ");
	Единицы.Добавить("ШТ");
	Единицы.Добавить("УП");
	Единицы.Добавить("УПАК");
	Единицы.Добавить("РУЛ");
	Единицы.Добавить("КОМПЛ");
	Единицы.Добавить("ПАРА");
	
	Возврат Единицы;
	
КонецФункции


Функция ЭтоЕдиницаИзмерения(Слово)
	
	Единицы = ПолучитьСписокЕдиницИзмерения();
	
	Возврат Единицы.Найти(Слово) <> Неопределено;
	
КонецФункции


Функция ЭтоПоисковыйОператор(Слово)
	
	Возврат Слово = "И"
		Или Слово = "ИЛИ"
		Или Слово = "НЕ"
		Или Слово = "РЯДОМ";
	
КонецФункции


Функция ЭтоСтрокаИзЦифр(Знач Строка)
	
	Строка = СокрЛП(Строка);
	
	Если ПустаяСтрока(Строка) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Для НомерСимвола = 1 По СтрДлина(Строка) Цикл
		
		Символ = Сред(Строка, НомерСимвола, 1);
		
		Если Найти("0123456789", Символ) = 0 Тогда
			Возврат Ложь;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

#КонецОбласти


#Область ПроверкаРелевантности

Функция ПоискДопустим(ПараметрыПоиска)
	
	КоличествоТекстовыхСлов = ПараметрыПоиска.ТекстовыеСлова.Количество();
	КоличествоКороткихТокенов = ПараметрыПоиска.КороткиеТокены.Количество();
	КоличествоМетрик = ПараметрыПоиска.Метрики.Количество();
	КоличествоЧисел = ПараметрыПоиска.Числа.Количество();
	
	// Нормальный товарный поиск: Болт, Гайка, Шайба, Бур и т.п.
	Если КоличествоТекстовыхСлов > 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	// М6, М8, М10 — допустимый поиск.
	Если КоличествоМетрик > 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	// 14 310 — допустимо.
	Если КоличествоЧисел >= 2 Тогда
		Возврат Истина;
	КонецЕсли;
	
	// Один короткий токен или одно число — слишком шумно.
	Возврат Ложь;
	
КонецФункции


Функция НаименованиеСоответствуетПоиску(Знач Наименование, ПараметрыПоиска)
	
	ПараметрыНаименования = РазобратьСтрокуПоискаНоменклатуры(Наименование);
	
	// Все обычные слова обязательны.
	Для Каждого Слово Из ПараметрыПоиска.ТекстовыеСлова Цикл
		
		Если ПараметрыНаименования.ТекстовыеСлова.Найти(Слово) = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
		
	КонецЦикла;
	
	// Все короткие важные токены обязательны: ОЦ и т.п.
	Для Каждого Токен Из ПараметрыПоиска.КороткиеТокены Цикл
		
		Если ПараметрыНаименования.КороткиеТокены.Найти(Токен) = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
		
	КонецЦикла;
	
	// Все метрические размеры обязательны: М6, М8, М10.
	Для Каждого Метрика Из ПараметрыПоиска.Метрики Цикл
		
		Если ПараметрыНаименования.Метрики.Найти(Метрика) = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
		
	КонецЦикла;
	
	// Размерные выражения обязательны:
	// 5,5*19 НЕ равно 5,5*76.
	Если ПараметрыПоиска.Свойство("РазмерныеВыражения") Тогда
		
		Для Каждого РазмерноеВыражение Из ПараметрыПоиска.РазмерныеВыражения Цикл
			
			Если Не ПараметрыНаименования.Свойство("РазмерныеВыражения")
				Или ПараметрыНаименования.РазмерныеВыражения.Найти(РазмерноеВыражение) = Неопределено Тогда
				
				Возврат Ложь;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	// Составные размеры обязательны:
	// 2,5-5 НЕ равно 2,5-4.
	Для Каждого СоставнойРазмер Из ПараметрыПоиска.СоставныеРазмеры Цикл
		
		Если ПараметрыНаименования.СоставныеРазмеры.Найти(СоставнойРазмер) = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
		
	КонецЦикла;
	
	// Размеры с единицами обязательны:
	// 25ММ НЕ равно 25-7.
	Для Каждого РазмерСЕдиницей Из ПараметрыПоиска.РазмерыСЕдиницами Цикл
		
		Если ПараметрыНаименования.РазмерыСЕдиницами.Найти(РазмерСЕдиницей) = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
		
	КонецЦикла;
	
	// ВАЖНО:
	// Простые числа проверяем всегда.
	// Это исправляет ошибку:
	// 5,5*19 не должно находить 5,5*76.
	Для Каждого Число Из ПараметрыПоиска.Числа Цикл
		
		Если ПараметрыНаименования.Числа.Найти(Число) = Неопределено Тогда
			Возврат Ложь;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

Функция РассчитатьОценкуПоискаНоменклатуры(
	Знач Наименование,
	ПараметрыПоиска,
	Знач ИсходнаяСтрокаПоиска = "")
	
	Оценка = 0;
	
	Если Не ПустаяСтрока(ИсходнаяСтрокаПоиска) Тогда
		
		Если НормализоватьСтрокуДляТочногоСравнения(Наименование)
			= НормализоватьСтрокуДляТочногоСравнения(ИсходнаяСтрокаПоиска) Тогда
			
			Оценка = Оценка + 10000;
			
		КонецЕсли;
		
	КонецЕсли;
	
	ПараметрыНаименования = РазобратьСтрокуПоискаНоменклатуры(Наименование);
	
	Для Каждого Слово Из ПараметрыПоиска.ТекстовыеСлова Цикл
		
		Если ПараметрыНаименования.ТекстовыеСлова.Найти(Слово) <> Неопределено Тогда
			Оценка = Оценка + 100;
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого Токен Из ПараметрыПоиска.КороткиеТокены Цикл
		
		Если ПараметрыНаименования.КороткиеТокены.Найти(Токен) <> Неопределено Тогда
			Оценка = Оценка + 80;
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого Метрика Из ПараметрыПоиска.Метрики Цикл
		
		Если ПараметрыНаименования.Метрики.Найти(Метрика) <> Неопределено Тогда
			Оценка = Оценка + 80;
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого СоставнойРазмер Из ПараметрыПоиска.СоставныеРазмеры Цикл
		
		Если ПараметрыНаименования.СоставныеРазмеры.Найти(СоставнойРазмер) <> Неопределено Тогда
			Оценка = Оценка + 200;
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого РазмерСЕдиницей Из ПараметрыПоиска.РазмерыСЕдиницами Цикл
		
		Если ПараметрыНаименования.РазмерыСЕдиницами.Найти(РазмерСЕдиницей) <> Неопределено Тогда
			Оценка = Оценка + 200;
		КонецЕсли;
		
	КонецЦикла;
	
	Для Каждого Число Из ПараметрыПоиска.Числа Цикл
		
		Если ПараметрыНаименования.Числа.Найти(Число) <> Неопределено Тогда
			Оценка = Оценка + 40;
		КонецЕсли;
		
	КонецЦикла;
	
	// Чем короче наименование, тем оно ближе к запросу.
	Оценка = Оценка - СтрДлина(Наименование) / 10;
	
	Возврат Оценка;
	
КонецФункции

Функция НормализоватьСтрокуДляСравнения(Знач Строка)
	
	Строка = ВРег(СокрЛП(Строка));
	Строка = ПодготовитьСтрокуКРазбору(Строка);
	
	Возврат " " + Строка + " ";
	
КонецФункции

#КонецОбласти


#Область ФильтрацияКандидатов

Функция ОтфильтроватьКандидатовПоНаименованию(
	Кандидаты,
	ПараметрыПоиска,
	РазмерПорции,
	Знач ИсходнаяСтрокаПоиска = "")
	
	Результат = Новый Массив;
	
	Если Кандидаты.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК Ссылка,
	|	Номенклатура.Наименование КАК Наименование
	|ИЗ
	|	Справочник.МС_НоменклатураБП КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Ссылка В (&Кандидаты)
	|	И НЕ Номенклатура.ПометкаУдаления
	|	И НЕ Номенклатура.ЭтоГруппа";
	
	Запрос.УстановитьПараметр("Кандидаты", Кандидаты);
	
	Таблица = Новый ТаблицаЗначений;
	Таблица.Колонки.Добавить("Ссылка");
	Таблица.Колонки.Добавить("Наименование");
	Таблица.Колонки.Добавить("Оценка");
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если Не НаименованиеСоответствуетПоиску(
			Выборка.Наименование,
			ПараметрыПоиска
		) Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = Таблица.Добавить();
		НоваяСтрока.Ссылка = Выборка.Ссылка;
		НоваяСтрока.Наименование = Выборка.Наименование;
		НоваяСтрока.Оценка = РассчитатьОценкуПоискаНоменклатуры(
	Выборка.Наименование,
	ПараметрыПоиска,
	ИсходнаяСтрокаПоиска
);
		
	КонецЦикла;
	
	Таблица.Сортировать("Оценка Убыв, Наименование Возр");
	
	Счетчик = 0;
	
	Для Каждого СтрокаТаблицы Из Таблица Цикл
		
		Результат.Добавить(СтрокаТаблицы.Ссылка);
		
		Счетчик = Счетчик + 1;
		
		Если Счетчик >= РазмерПорции Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти


#Область РезервныйПоиск

Функция НайтиНоменклатуруПоНаименованиюПодобно(
	ПараметрыПоиска,
	РазмерПорции)
	
	Результат = Новый Массив;
	
	Если Не ПоискДопустим(ПараметрыПоиска) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Условия = Новый Массив;
	
	ИндексПараметра = 0;
	
	Для Каждого Слово Из ПараметрыПоиска.ТекстовыеСлова Цикл
		
		ИмяПараметра = "Параметр" + Формат(ИндексПараметра, "ЧГ=0");
		
		Условия.Добавить(
			"ВРег(Номенклатура.Наименование) ПОДОБНО &" + ИмяПараметра
		);
		
		ИндексПараметра = ИндексПараметра + 1;
		
	КонецЦикла;
	
	Для Каждого Число Из ПараметрыПоиска.Числа Цикл
		
		ИмяПараметра = "Параметр" + Формат(ИндексПараметра, "ЧГ=0");
		
		Условия.Добавить(
			"ВРег(Номенклатура.Наименование) ПОДОБНО &" + ИмяПараметра
		);
		
		ИндексПараметра = ИндексПараметра + 1;
		
	КонецЦикла;
	
	Если Условия.Количество() = 0 Тогда
		Возврат Результат;
	КонецЕсли;
	
	ТекстУсловий = "";
	
	Для Индекс = 0 По Условия.Количество() - 1 Цикл
		
		Если ТекстУсловий <> "" Тогда
			ТекстУсловий = ТекстУсловий + "
			|	И ";
		КонецЕсли;
		
		ТекстУсловий = ТекстУсловий + Условия[Индекс];
		
	КонецЦикла;
	
	КоличествоДляВыборки = РазмерПорции * 5;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ " + Формат(КоличествоДляВыборки, "ЧГ=0") + "
	|	Номенклатура.Ссылка КАК Ссылка,
	|	Номенклатура.Наименование КАК Наименование
	|ИЗ
	|	Справочник.МС_НоменклатураБП КАК Номенклатура
	|ГДЕ
	|	НЕ Номенклатура.ПометкаУдаления
	|	И НЕ Номенклатура.ЭтоГруппа
	|	И " + ТекстУсловий + "
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура.Наименование";
	
	ИндексПараметра = 0;
	
	Для Каждого Слово Из ПараметрыПоиска.ТекстовыеСлова Цикл
		
		ИмяПараметра = "Параметр" + Формат(ИндексПараметра, "ЧГ=0");
		Запрос.УстановитьПараметр(ИмяПараметра, "%" + Слово + "%");
		
		ИндексПараметра = ИндексПараметра + 1;
		
	КонецЦикла;
	
	Для Каждого Число Из ПараметрыПоиска.Числа Цикл
		
		ИмяПараметра = "Параметр" + Формат(ИндексПараметра, "ЧГ=0");
		Запрос.УстановитьПараметр(ИмяПараметра, "%" + Число + "%");
		
		ИндексПараметра = ИндексПараметра + 1;
		
	КонецЦикла;
	
	Таблица = Новый ТаблицаЗначений;
	Таблица.Колонки.Добавить("Ссылка");
	Таблица.Колонки.Добавить("Наименование");
	Таблица.Колонки.Добавить("Оценка");
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		// Даже после ПОДОБНО дополнительно проверяем
		// строгими правилами, чтобы отсечь мусор.
		Если Не НаименованиеСоответствуетПоиску(
			Выборка.Наименование,
			ПараметрыПоиска
		) Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = Таблица.Добавить();
		НоваяСтрока.Ссылка = Выборка.Ссылка;
		НоваяСтрока.Наименование = Выборка.Наименование;
		НоваяСтрока.Оценка = РассчитатьОценкуПоискаНоменклатуры(
			Выборка.Наименование,
			ПараметрыПоиска
		);
		
	КонецЦикла;
	
	Таблица.Сортировать("Оценка Убыв, Наименование Возр");
	
	Счетчик = 0;
	
	Для Каждого СтрокаТаблицы Из Таблица Цикл
		
		Результат.Добавить(СтрокаТаблицы.Ссылка);
		
		Счетчик = Счетчик + 1;
		
		Если Счетчик >= РазмерПорции Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти


#Область СлужебныеПроцедурыИФункции

Функция ПолучитьБезопасныйРазмерПорции(РазмерПорции)
	
	Если РазмерПорции = Неопределено Тогда
		Возврат 20;
	КонецЕсли;
	
	Если РазмерПорции <= 0 Тогда
		Возврат 20;
	КонецЕсли;
	
	Если РазмерПорции > 100 Тогда
		Возврат 100;
	КонецЕсли;
	
	Возврат РазмерПорции;
	
КонецФункции

#КонецОбласти