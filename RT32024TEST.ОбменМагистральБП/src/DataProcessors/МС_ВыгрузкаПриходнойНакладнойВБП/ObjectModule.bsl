

Функция ДатаВСтрокуJSON(ДатаЗначение)
	
	Если Не ЗначениеЗаполнено(ДатаЗначение) Тогда
		Возврат Неопределено; // В JSON будет null
	КонецЕсли;
	
	Возврат Формат(ДатаЗначение, "ДФ=yyyy-MM-dd")
		+ "T"
		+ Формат(ДатаЗначение, "ДФ=HH:mm:ss");
	
КонецФункции

Функция ГУИД(СсылкаНаОбъект)
	
	Если Не ЗначениеЗаполнено(СсылкаНаОбъект) Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат СокрЛП(Строка(СсылкаНаОбъект.УникальныйИдентификатор()));
	
КонецФункции

Функция БезопаснаяСтрока(Значение)
	
	Если Значение = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Значение) Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат СокрЛП(Строка(Значение));
	
КонецФункции

Функция СформироватьJSONПриходнойНакладной(ДокументСсылка)
	
	Данные = Новый Структура;
	
	Данные.Вставить("source", "retail");
	Данные.Вставить("guid", ГУИД(ДокументСсылка.Ссылка));
	//Данные.Вставить("number", ДокументСсылка.Номер);
	Данные.Вставить("date", ДатаВСтрокуJSON(ДокументСсылка.Дата));
	//Данные.Вставить("posted", ДокументСсылка.Проведен);
	Данные.Вставить("incoming_number", ДокументСсылка.НомерВходящегоДокумента);
	Данные.Вставить("incoming_date", ДатаВСтрокуJSON(ДокументСсылка.ДатаВходящегоДокумента));
	
	Данные.Вставить("comment", ДокументСсылка.Комментарий);
	Данные.Вставить("amount_includes_vat", ДокументСсылка.СуммаВключаетНДС);
	Данные.Вставить("total_amount", ДокументСсылка.СуммаДокумента);
	Данные.Вставить("is_upd", Истина);
	Данные.Вставить("GISM", ДокументСсылка.ЕстьМаркируемаяПродукцияГИСМ);
	
	Организация = Новый Структура;
	Организация.Вставить("guid", ГУИД(ДокументСсылка.Организация));
	Организация.Вставить("inn", ДокументСсылка.Организация.ИНН);
	Организация.Вставить("kpp", ДокументСсылка.Организация.КПП);
	Данные.Вставить("organization", Организация);
	
	Контрагент = Новый Структура;
	Контрагент.Вставить("guid", ГУИД(ДокументСсылка.Контрагент));
	Контрагент.Вставить("inn", ДокументСсылка.Контрагент.ИНН);
	Контрагент.Вставить("kpp", ДокументСсылка.Контрагент.КПП);
	Контрагент.Вставить("name", ДокументСсылка.Контрагент.Наименование);
	Данные.Вставить("Counterparty", Контрагент);
	
	ДоговорКонтрагент = Новый Структура;
	ДоговорКонтрагент.Вставить("guid", ГУИД(ДокументСсылка.Договор));
	ДоговорКонтрагент.Вставить("name", ДокументСсылка.Договор.Наименование);
	Данные.Вставить("Counterparty_agreement", ДоговорКонтрагент);
	
	Склад = Новый Структура;  
	Склад.Вставить("guid", ГУИД(ДокументСсылка.СтруктурнаяЕдиница));
	Склад.Вставить("name", ДокументСсылка.СтруктурнаяЕдиница.Наименование);
	Данные.Вставить("warehouse", Склад);
	
	Запасы = Новый Массив;
	
	Для Каждого СтрокаТЧ Из ДокументСсылка.Запасы Цикл
		
		НоменклатураJSON = Новый Структура;
		НоменклатураJSON.Вставить("guid", ГУИД(СтрокаТЧ.Номенклатура));
		НоменклатураJSON.Вставить("name", СтрокаТЧ.Номенклатура.Наименование);
		НоменклатураJSON.Вставить("article", СтрокаТЧ.Номенклатура.Артикул);
		НоменклатураJSON.Вставить("Country", Строка(СтрокаТЧ.Номенклатура.СтранаПроисхождения));
		НоменклатураJSON.Вставить("unit", Строка(СтрокаТЧ.ЕдиницаИзмерения));
		
		Если ЗначениеЗаполнено(СтрокаТЧ.Номенклатура.МС_НоменклатураБП) Тогда
			НоменклатураJSON.Вставить("guid_bp", БезопаснаяСтрока(СтрокаТЧ.Номенклатура.МС_НоменклатураБП.СсылкаВДругойИБ));
		Иначе
			НоменклатураJSON.Вставить("guid_bp", "");
		КонецЕсли;
		
		СтрокаJSON = Новый Структура;
		СтрокаJSON.Вставить("Nomenclature", НоменклатураJSON);
		СтрокаJSON.Вставить("quantity", СтрокаТЧ.Количество);
		СтрокаJSON.Вставить("price", СтрокаТЧ.Цена);
		СтрокаJSON.Вставить("amount", СтрокаТЧ.Сумма);
		СтрокаJSON.Вставить("vat_rate", Строка(СтрокаТЧ.СтавкаНДС));
		СтрокаJSON.Вставить("vat_amount", СтрокаТЧ.СуммаНДС);
		СтрокаJSON.Вставить("total", СтрокаТЧ.Всего);
		
		Запасы.Добавить(СтрокаJSON);
		
	КонецЦикла;
	
	Данные.Вставить("items", Запасы);
	
	Возврат Данные;
	
КонецФункции

Функция ЗаписатьДанныеВJSON(Данные)
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	
	ЗаписатьJSON(ЗаписьJSON, Данные);
	
	СтрокаJSON = ЗаписьJSON.Закрыть();
	
	Возврат СтрокаJSON;
	
КонецФункции

Функция ПрочитатьJSONИзСтроки(СтрокаJSON)
	
	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(СтрокаJSON);
	
	Данные = ПрочитатьJSON(ЧтениеJSON);
	
	ЧтениеJSON.Закрыть();
	
	Возврат Данные;
	
КонецФункции

Функция ОтправитьJSONВБП(СтрокаJSON, GUIDДокументаИсточник = "")
	
	Сервер = СокрЛП(Строка(Константы.МС_АдресБП.Получить()));
	Порт = Константы.МС_ПортБП.Получить();
	Пользователь = СокрЛП(Строка(Константы.МС_ПользовательБП.Получить()));
	Пароль = Строка(Константы.МС_ПарольБП.Получить());
	
	ПутьHTTPСервиса = СокрЛП(Строка(Константы.МС_ПутьHTTPСервисаБП.Получить()));
	Таймаут = Константы.МС_ТаймаутHTTPБП.Получить();
	
	Если ПустаяСтрока(Сервер) Или ПустаяСтрока(ПутьHTTPСервиса) Тогда
		ВызватьИсключение "Не заполнены настройки обмена с БП (адрес/путь HTTP-сервиса).";
	КонецЕсли;
	
	Если Порт = Неопределено Или Порт = 0 Тогда
		Порт = 80;
	КонецЕсли;
	
	Если Таймаут = Неопределено Или Таймаут <= 0 Тогда
		Таймаут = 60;
	КонецЕсли;
	
	Попытка
		
		Соединение = Новый HTTPСоединение(
			Сервер,
			Порт,
			Пользователь,
			Пароль,
			,
			Таймаут,
			
		);
	
		Запрос = Новый HTTPЗапрос(ПутьHTTPСервиса);
		Запрос.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Запрос.Заголовки.Вставить("Accept", "application/json");
		Запрос.УстановитьТелоИзСтроки(СтрокаJSON, КодировкаТекста.UTF8);
	
		Ответ = Соединение.ВызватьHTTPМетод("POST", Запрос);
	
		ТелоОтвета = Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
	
		ОтветСтруктура = ПрочитатьJSONИзСтроки(ТелоОтвета);
	
		Если Ответ.КодСостояния = 200 Тогда
			Текст = СтрШаблон("Документ успешно загружен в бухгалтерию: %1", ОтветСтруктура.document_ref);
		
			//@skip-check undefined-variable
			ОбщегоНазначения.СообщитьПользователю(Текст);
			//@skip-check undefined-variable
			ОбщегоНазначения.СообщитьПользователю(ОтветСтруктура.ref);
			
			//@skip-check undefined-variable
			ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(
				"МС_ОбменРозницаБП",
				УровеньЖурналаРегистрации.Информация,
				,
				,
				"Успешная выгрузка в БП (GUID=" + GUIDДокументаИсточник + ", БП.Ссылка=" + Строка(ОтветСтруктура.document_ref) + ")."
			);
		Иначе
		
			ВызватьИсключение 
				"Ошибка HTTP при выгрузке в Бухгалтерию. Код: "
				+ Строка(Ответ.КодСостояния)
				+ ". Ответ: "
				+ ТелоОтвета;
			
		КонецЕсли;
	
		Возврат ТелоОтвета;
		
	Исключение
		
		ТекстОшибки = "Ошибка обмена с БП";
		Если Не ПустаяСтрока(GUIDДокументаИсточник) Тогда
			ТекстОшибки = ТекстОшибки + " (GUID=" + GUIDДокументаИсточник + ")";
		КонецЕсли;
		ТекстОшибки = ТекстОшибки + ": " + ОписаниеОшибки();
		
		//@skip-check undefined-variable
		ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(
			"МС_ОбменРозницаБП",
			УровеньЖурналаРегистрации.Ошибка,
			,
			,
			ТекстОшибки
		);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецПопытки;
	
КонецФункции

Процедура ОтправитьПриходнуюНакладную() Экспорт
	
	Данные = СформироватьJSONПриходнойНакладной(СсылкаНаДокумент);
	СтрокаJSON = ЗаписатьДанныеВJSON(Данные);
	ОтправитьJSONВБП(СтрокаJSON, Данные.guid);
	 
КонецПроцедуры

