#Область ОбработчикиКомандФормы
&НаКлиенте
Процедура МС_ВыгрузитьВБППосле(Команда)
	Если Объект.Ссылка.Пустая() Тогда
        Сообщение = Новый СообщениеПользователю;
		Сообщение.Текст = "Сначала запишите документ.";
		Сообщение.Сообщить();
        Возврат;
	КонецЕсли;
	         
	ПараметрыФормы = Новый Структура("Ссылка", Объект.Ссылка);
	ОткрытьФорму("Обработка.МС_ВыгрузитьСчетНаОплатуПоставщика.Форма", ПараметрыФормы);
КонецПроцедуры
#КонецОбласти
