#Область ФормированиеДанных


// Формирует структуру с данными приходной накладной для обмена с БП.
//
// Параметры:
//   Ссылка - ДокументСсылка.ПриходнаяНакладная - ссылка на документ
//
// Возвращаемое значение:
//   Структура:
//     * source - Строка - источник данных ("retail")
//     * guid - Строка - уникальный идентификатор документа
//     * date - Строка - дата документа
//     * incoming_number - Строка - номер входящего документа
//     * incoming_date - Строка - дата входящего документа
//     * comment - Строка - комментарий
//     * amount_includes_vat - Булево - сумма включает НДС
//     * total_amount - Число - сумма документа
//     * is_upd - Булево - универсальный передаточный документ
//     * GISM - Булево - маркируемая продукция ГИС М
//     * organization - Структура:
//         ** guid - Строка - ГУИД организации
//         ** inn - Строка - ИНН организации
//         ** kpp - Строка - КПП организации
//     * Counterparty - Структура:
//         ** guid - Строка - ГУИД контрагента
//         ** inn - Строка - ИНН контрагента
//         ** kpp - Строка - КПП контрагента
//         ** name - Строка - наименование контрагента
//     * Counterparty_agreement - Структура:
//         ** guid - Строка - ГУИД договора
//         ** name - Строка - наименование договора
//     * warehouse - Структура:
//         ** guid - Строка - ГУИД склада
//         ** name - Строка - наименование склада
//     * items - Массив из Структура - строки табличной части Запасы:
//         ** Nomenclature - Структура:
//             *** guid - Строка - ГУИД номенклатуры
//             *** name - Строка - наименование
//             *** article - Строка - артикул
//             *** Country - Строка - страна происхождения
//             *** unit - Строка - единица измерения
//             *** guid_bp - Строка - ГУИД номенклатуры в БП
//         ** quantity - Число - количество
//         ** price - Число - цена
//         ** amount - Число - сумма
//         ** vat_rate - Строка - ставка НДС
//         ** vat_amount - Число - сумма НДС
//         ** total - Число - всего
Функция СформироватьJSONПриходнойНакладной(Знач Ссылка)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ПриходнаяНакладная.Ссылка) КАК ДокументГУИД,
		|	ПриходнаяНакладная.Дата КАК Дата,
		|	ПриходнаяНакладная.НомерВходящегоДокумента КАК НомерВходящегоДокумента,
		|	ПриходнаяНакладная.ДатаВходящегоДокумента КАК ДатаВходящегоДокумента,
		|	ПриходнаяНакладная.Комментарий КАК Комментарий,
		|	ПриходнаяНакладная.СуммаВключаетНДС КАК СуммаВключаетНДС,
		|	ПриходнаяНакладная.СуммаДокумента КАК СуммаДокумента,
		|	ПриходнаяНакладная.ЭтоУниверсальныйДокумент КАК ЭтоУниверсальныйДокумент,
		|	ПриходнаяНакладная.ЕстьМаркируемаяПродукцияГИСМ КАК ЕстьМаркируемаяПродукцияГИСМ,
		|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ПриходнаяНакладная.Организация) КАК ОрганизацияГУИД,
		|	ПриходнаяНакладная.Организация.ИНН КАК ОрганизацияИНН,
		|	ПриходнаяНакладная.Организация.КПП КАК ОрганизацияКПП,
		|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ПриходнаяНакладная.Контрагент) КАК КонтрагентГУИД,
		|	ПриходнаяНакладная.Контрагент.ИНН КАК КонтрагентИНН,
		|	ПриходнаяНакладная.Контрагент.КПП КАК КонтрагентКПП,
		|	ПриходнаяНакладная.Контрагент.Наименование КАК КонтрагентНаименование,
		|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ПриходнаяНакладная.Договор) КАК ДоговорГУИД,
		|	ПриходнаяНакладная.Договор.Наименование КАК ДоговорНаименование,
		|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ПриходнаяНакладная.СтруктурнаяЕдиница) КАК СтруктурнаяЕдиницаГУИД,
		|	ПриходнаяНакладная.СтруктурнаяЕдиница.Наименование КАК СтруктурнаяЕдиницаНаименование
		|ИЗ
		|	Документ.ПриходнаяНакладная КАК ПриходнаяНакладная
		|ГДЕ
		|	ПриходнаяНакладная.Ссылка = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	УНИКАЛЬНЫЙИДЕНТИФИКАТОР(ПриходнаяНакладнаяЗапасы.Номенклатура) КАК НоменклатураГУИД,
		|	ПриходнаяНакладнаяЗапасы.Номенклатура.Наименование КАК Наименование,
		|	ПриходнаяНакладнаяЗапасы.Номенклатура.Артикул КАК Артикул,
		|	ПРЕДСТАВЛЕНИЕ(ПриходнаяНакладнаяЗапасы.Номенклатура.СтранаПроисхождения) КАК СтранаПроисхождения,
		|	ПРЕДСТАВЛЕНИЕ(ПриходнаяНакладнаяЗапасы.Номенклатура.ЕдиницаИзмерения) КАК ЕдиницаИзмерения,
		|	ПриходнаяНакладнаяЗапасы.Номенклатура.МС_НоменклатураБП.СсылкаВДругойИБ КАК НоменклатураБПГУИД,
		|	ПриходнаяНакладнаяЗапасы.Количество КАК Количество,
		|	ПриходнаяНакладнаяЗапасы.Всего КАК Всего,
		|	ПриходнаяНакладнаяЗапасы.Цена КАК Цена,
		|	ПриходнаяНакладнаяЗапасы.Сумма КАК Сумма,
		|	ПРЕДСТАВЛЕНИЕ(ПриходнаяНакладнаяЗапасы.СтавкаНДС) КАК СтавкаНДС,
		|	ПриходнаяНакладнаяЗапасы.СуммаНДС КАК СуммаНДС
		|ИЗ
		|	Документ.ПриходнаяНакладная.Запасы КАК ПриходнаяНакладнаяЗапасы
		|ГДЕ
		|	ПриходнаяНакладнаяЗапасы.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Шапка = РезультатЗапроса[0].Выбрать();
	
	Шапка.Следующий();
	
	Данные = Новый Структура;
	
	//Реквизиты шапки документа
	Данные.Вставить("source", "ПриходнаяНакладная");
	Данные.Вставить("guid", XMLСтрока(Шапка.ДокументГУИД));
	Данные.Вставить("date", XMLСтрока(Шапка.Дата));
	Данные.Вставить("incoming_number", Шапка.НомерВходящегоДокумента);
	Данные.Вставить("incoming_date", XMLСтрока(Шапка.ДатаВходящегоДокумента));
	Данные.Вставить("comment", Шапка.Комментарий);
	Данные.Вставить("amount_includes_vat", Шапка.СуммаВключаетНДС);
	Данные.Вставить("total_amount", Шапка.СуммаДокумента);
	Данные.Вставить("is_upd", Шапка.ЭтоУниверсальныйДокумент);
	Данные.Вставить("GISM", Шапка.ЕстьМаркируемаяПродукцияГИСМ);
	
	Организация = Новый Структура;
	Организация.Вставить("guid", XMLСтрока(Шапка.ОрганизацияГУИД));
	Организация.Вставить("inn", Шапка.ОрганизацияИНН);
	Организация.Вставить("kpp", Шапка.ОрганизацияКПП);
	Данные.Вставить("organization", Организация);
	
	Контрагент = Новый Структура;
	Контрагент.Вставить("guid", XMLСтрока(Шапка.КонтрагентГУИД));
	Контрагент.Вставить("inn", Шапка.КонтрагентИНН);
	Контрагент.Вставить("kpp", Шапка.КонтрагентКПП);
	Контрагент.Вставить("name", Шапка.КонтрагентНаименование);
	Данные.Вставить("Counterparty", Контрагент);
	
	ДоговорКонтрагент = Новый Структура;
	ДоговорКонтрагент.Вставить("guid", XMLСтрока(Шапка.ДоговорГУИД));
	ДоговорКонтрагент.Вставить("name", Шапка.ДоговорНаименование);
	Данные.Вставить("Counterparty_agreement", ДоговорКонтрагент);
	
	Склад = Новый Структура;  
	Склад.Вставить("guid", XMLСтрока(Шапка.СтруктурнаяЕдиницаГУИД));
	Склад.Вставить("name", Шапка.СтруктурнаяЕдиницаНаименование);
	Данные.Вставить("warehouse", Склад);
	
	
	//Реквизиты табличной части документа
	СтрокаЗапасы = РезультатЗапроса[1].Выбрать();
	Запасы = Новый Массив; //Массив из структур
	
	Пока СтрокаЗапасы.Следующий() Цикл
		
		НоменклатураJSON = Новый Структура;
		НоменклатураJSON.Вставить("guid", XMLСтрока(СтрокаЗапасы.НоменклатураГУИД));
		НоменклатураJSON.Вставить("name", СтрокаЗапасы.Наименование);
		НоменклатураJSON.Вставить("article", СтрокаЗапасы.Артикул);
		НоменклатураJSON.Вставить("Country", СтрокаЗапасы.СтранаПроисхождения);
		НоменклатураJSON.Вставить("unit", СтрокаЗапасы.ЕдиницаИзмерения);
		НоменклатураJSON.Вставить("guid_bp", СтрокаЗапасы.НоменклатураБПГУИД);
		
		СтрокаJSON = Новый Структура;
		СтрокаJSON.Вставить("Nomenclature", НоменклатураJSON);
		СтрокаJSON.Вставить("quantity", СтрокаЗапасы.Количество);
		СтрокаJSON.Вставить("price", СтрокаЗапасы.Цена);
		СтрокаJSON.Вставить("amount", СтрокаЗапасы.Сумма);
		СтрокаJSON.Вставить("vat_rate", СтрокаЗапасы.СтавкаНДС);
		СтрокаJSON.Вставить("vat_amount", СтрокаЗапасы.СуммаНДС);
		СтрокаJSON.Вставить("total", СтрокаЗапасы.Всего);
		
		Запасы.Добавить(СтрокаJSON);
		
	КонецЦикла;
	
	Данные.Вставить("items", Запасы);
	
	Возврат Данные;
	
КонецФункции

#КонецОбласти

#Область ОтправкаДанных

// Отправляет данные в формате JSON в 1С:Бухгалтерию через HTTP-сервис
//
// Параметры:
//   СтрокаJSON - Строка - строка JSON для отправки в HTTP-сервис
//   GUIDДокументаИсточник - Строка - GUID документа-источока для записи в журнал регистрации
//
// Возвращаемое значение:
//   Строка - тело ответа HTTP-сервиса
Функция ОтправитьJSONВБП(СтрокаJSON, GUIDДокументаИсточник = "")
	
	Сервер = СокрЛП(Строка(Константы.МС_АдресБП.Получить()));
	Порт = Константы.МС_ПортБП.Получить();
	Пользователь = СокрЛП(Строка(Константы.МС_ПользовательБП.Получить()));
	Пароль = Строка(Константы.МС_ПарольБП.Получить());
	
	ПутьHTTPСервиса = СокрЛП(Строка(Константы.МС_ПутьHTTPСервисаБП.Получить()));
	Таймаут = Константы.МС_ТаймаутHTTPБП.Получить();
	
	Если ПустаяСтрока(Сервер) Или ПустаяСтрока(ПутьHTTPСервиса) Тогда
		ВызватьИсключение "Не заполнены настройки обмена с БП (адрес/путь HTTP-сервиса).";
	КонецЕсли;
	
	Если Порт = Неопределено Или Порт = 0 Тогда
		Порт = 80;
	КонецЕсли;
	
	Если Таймаут = Неопределено Или Таймаут <= 0 Тогда
		Таймаут = 60;
	КонецЕсли;
	
	Попытка
		
		Соединение = Новый HTTPСоединение(
			Сервер,
			Порт,
			Пользователь,
			Пароль,
			,
			Таймаут,
			
		);
	
		Запрос = Новый HTTPЗапрос(ПутьHTTPСервиса);
		Запрос.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
		Запрос.Заголовки.Вставить("Accept", "application/json");
		Запрос.УстановитьТелоИзСтроки(СтрокаJSON, КодировкаТекста.UTF8);
	
		Ответ = Соединение.ВызватьHTTPМетод("POST", Запрос);
	
		ТелоОтвета = Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
	
		Если Ответ.КодСостояния = 200 Тогда
		//@skip-check undefined-variable
		ОтветСтруктура = МС_ВыгрузкаСервер.ПрочитатьJSONИзСтроки(ТелоОтвета);
		
			Текст = СтрШаблон("Документ успешно загружен в бухгалтерию: %1", ОтветСтруктура.document_ref);
		
			//@skip-check undefined-variable
			ОбщегоНазначения.СообщитьПользователю(Текст);
			
			//@skip-check undefined-variable
			ОбщегоНазначения.СообщитьПользователю(ОтветСтруктура.ref);
			
			//@skip-check undefined-variable
			ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(
				"МС_ОбменРозницаБП",
				УровеньЖурналаРегистрации.Информация,
				,
				,
				"Успешная выгрузка в БП (GUID=" + GUIDДокументаИсточник + ", БП.Ссылка=" + Строка(ОтветСтруктура.document_ref) + ")."
			);
		Иначе
		
			ВызватьИсключение 
				"Ошибка HTTP при выгрузке в Бухгалтерию. Код: "
				+ Строка(Ответ.КодСостояния)
				+ ". Ответ: "
				+ ТелоОтвета;
			
		КонецЕсли;
	
		Возврат ТелоОтвета;
		
	Исключение
		
		ТекстОшибки = "Ошибка обмена с БП";
		Если Не ПустаяСтрока(GUIDДокументаИсточник) Тогда
			ТекстОшибки = ТекстОшибки + " (GUID=" + GUIDДокументаИсточник + ")";
		КонецЕсли;
		ТекстОшибки = ТекстОшибки + ": " + ОписаниеОшибки();
		
		//@skip-check undefined-variable
		ЖурналРегистрации.ДобавитьСообщениеДляЖурналаРегистрации(
			"МС_ОбменРозницаБП",
			УровеньЖурналаРегистрации.Ошибка,
			,
			,
			ТекстОшибки
		);
		
		ВызватьИсключение ТекстОшибки;
		
	КонецПопытки;
	
КонецФункции

#КонецОбласти

#Область ПрограммныйИнтерфейс

// Отправляет приходную накладную в систему БП в формате JSON
Процедура ОтправитьПриходнуюНакладную() Экспорт
	
	Данные = СформироватьJSONПриходнойНакладной(Ссылка);
	СтрокаJSON = МС_ВыгрузкаСервер.ЗаписатьДанныеВJSON(Данные);
	ОтправитьJSONВБП(СтрокаJSON, Данные.guid);
	 
КонецПроцедуры

#КонецОбласти
